  <!-- 7. DATABASE SCHEMA -->
  <h2>7. Database Schema</h2>
  <table>
    <tr>
      <th>Collection</th>
      <th>Key Data Fields</th>
      <th>Purpose</th>
    </tr>
    <tr>
      <td><code>users</code></td>
      <td>uid, role, connectionCode, children[]</td>
      <td>User profiles and links.</td>
    </tr>
    <tr>
      <td><code>locations</code></td>
      <td>latitude, longitude, timestamp</td>
      <td>Real-time GPS tracking logs.</td>
    </tr>
    <tr>
      <td><code>alerts</code></td>
      <td>type (panic/boundary), message, senderId</td>
      <td>Emergency logs and notifications.</td>
    </tr>
  </table>

